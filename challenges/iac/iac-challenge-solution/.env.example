# Copie para .env na raiz deste diretório (iac-challenge-solution/) e ajuste.
# O arquivo .env não é versionado (ver .gitignore).
#
# O Terraform mapeia TF_VAR_<nome> à variável <nome>. Estes -var são passados
# pelos scripts subir/descer com precedência acima de terraform.tfvars.
#
# Obrigatório para apply/destroy (project_id do GCP):
TF_VAR_project_id=meu-projeto-123
#
# Opcionais (sobrescrevem predefinidos de variables.tf se definidos):
# TF_VAR_region=southamerica-east1
# TF_VAR_zone=southamerica-east1-a
# TF_VAR_subnetwork_cidr=10.0.0.0/20
# TF_VAR_proxy_subnetwork_cidr=10.0.16.0/24
# TF_VAR_machine_type=e2-micro
# TF_VAR_min_replicas=1
# TF_VAR_max_replicas=2
# TF_VAR_boot_disk_size_gb=20
# TF_VAR_ssh_ingress_cidr=0.0.0.0/0
# TF_VAR_app_secret_id=segredo-ja-criado
#
# Credenciais (opcional, se não usar gcloud application-default):
# export GOOGLE_APPLICATION_CREDENTIALS=/caminho/seguro/para-sa.json
#
# Mapa de etiquetas (JSON numa linha):
# TF_VAR_common_labels='{"project":"iac-challenge","cost_env":"dev"}'
