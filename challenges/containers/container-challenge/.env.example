# Variáveis de ambiente para Open5GS Containerizado
# Copie este arquivo para .env e ajuste conforme necessário

# Imagem base do Open5GS (contém todos os serviços)
OPEN5GS_IMAGE=gradiant/open5gs:2.7.6

# Imagem do MongoDB
MONGODB_IMAGE=mongo:7.0

# Imagem do UERANSIM
UERANSIM_IMAGE=gradiant/ueransim:3.2.6

# Imagem do Data Network
DN_IMAGE=alpine:latest
